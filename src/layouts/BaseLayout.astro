---
import "@/styles/global.css";
import { SOFT_GRID_DEFAULTS, type SoftGridConfig } from "./constants";

export type { SoftGridConfig };

interface Props extends Partial<SoftGridConfig> {
  title?: string;
  description?: string;
  softGridId?: string;
}

const {
  title = "Martin Viera | Front-End Developer",
  description = "Front-End Developer portfolio showcasing projects built with React, Next.js, Astro, TypeScript, and Tailwind CSS.",
  softGridId = crypto.randomUUID(),
  grid = SOFT_GRID_DEFAULTS.grid,
  speedX = SOFT_GRID_DEFAULTS.speedX,
  speedY = SOFT_GRID_DEFAULTS.speedY,
} = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      name: "Martin Viera",
      jobTitle: "Front-End Developer",
      url: Astro.site ?? undefined,
      address: {
        "@type": "PostalAddress",
        addressLocality: "Mar del Plata",
        addressCountry: "AR",
      },
    },
    {
      "@type": "WebSite",
      name: "Martin Viera Portfolio",
      description,
      inLanguage: "en",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body
    class="relative isolate min-h-dvh bg-background"
    data-soft-grid={softGridId}
    data-grid={grid}
    data-speed-x={speedX}
    data-speed-y={speedY}
  >
    <a href="#main-content" class="sr-only">Skip to main content</a>
    <canvas
      class="absolute inset-0 -z-10 w-full h-full block pointer-events-none"
      aria-hidden="true"></canvas>
    <slot />
  </body>
</html>
