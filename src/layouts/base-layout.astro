---
import "@/styles/global.css";
import { Font } from "astro:assets";
import { PROFILE } from "@/shared/constants/profile";
import { SEO_DEFAULTS, SOFT_GRID_DEFAULTS } from "./constants";

import type { SoftGridConfig } from "./types";

interface Props extends Partial<SoftGridConfig> {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  softGridId?: string;
}

const {
  title = SEO_DEFAULTS.title,
  description = SEO_DEFAULTS.description,
  image = SEO_DEFAULTS.imagePath,
  imageAlt = SEO_DEFAULTS.imageAlt,
  softGridId = crypto.randomUUID(),
  grid = SOFT_GRID_DEFAULTS.grid,
  speedX = SOFT_GRID_DEFAULTS.speedX,
  speedY = SOFT_GRID_DEFAULTS.speedY,
} = Astro.props;

const seo = {
  title,
  description,
  siteName: SEO_DEFAULTS.siteName,
  url: new URL(Astro.url.pathname, Astro.site).href,
  image: new URL(image, Astro.site).href,
  imageAlt,
  imageWidth: SEO_DEFAULTS.imageWidth,
  imageHeight: SEO_DEFAULTS.imageHeight,
  imageType: SEO_DEFAULTS.imageType,
  locale: SEO_DEFAULTS.locale,
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      name: PROFILE.name,
      jobTitle: PROFILE.jobTitle,
      url: Astro.site ?? undefined,
      address: {
        "@type": "PostalAddress",
        addressLocality: PROFILE.location,
        addressCountry: "AR",
      },
    },
    {
      "@type": "WebSite",
      name: SEO_DEFAULTS.siteName,
      description: seo.description,
      inLanguage: "en",
    },
  ],
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />

    <link rel="icon" href="/favicon.ico?v=2" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="canonical" href={seo.url} />

    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={seo.description} />

    <title>{seo.title}</title>

    <slot name="head" />

    <Font cssVariable="--font-SpaceGrotesk" />
    <Font cssVariable="--font-JetBrainsMono" />

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp, Telegram, Discord, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={seo.siteName} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.url} />
    <meta property="og:locale" content={seo.locale} />
    <meta property="og:image" content={seo.image} />
    <meta property="og:image:secure_url" content={seo.image} />
    <meta property="og:image:type" content={seo.imageType} />
    <meta property="og:image:width" content={String(seo.imageWidth)} />
    <meta property="og:image:height" content={String(seo.imageHeight)} />
    <meta property="og:image:alt" content={seo.imageAlt} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />
    <meta name="twitter:image:alt" content={seo.imageAlt} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body
    class="relative isolate min-h-dvh bg-background"
    data-soft-grid={softGridId}
    data-grid={grid}
    data-speed-x={speedX}
    data-speed-y={speedY}
  >
    <a href="#main-content" class="sr-only">Skip to main content</a>

    <canvas
      class="absolute inset-0 -z-10 block h-full w-full pointer-events-none"
      aria-hidden="true"></canvas>

    <slot />

    <script>
      const loadGridAnimation = () => {
        void import("./logic/background-animation/body-grid-animation").then(
          ({ bodyGridAnimation }) => bodyGridAnimation(),
        );
      };

      const scheduleWhenIdle = (run: () => void) => {
        if ("requestIdleCallback" in window) {
          requestIdleCallback(run, { timeout: 4_000 });
        } else {
          setTimeout(run, 200);
        }
      };

      const scheduleAfterLoad = () => {
        if (document.readyState === "complete") {
          scheduleWhenIdle(loadGridAnimation);
          return;
        }

        window.addEventListener(
          "load",
          () => scheduleWhenIdle(loadGridAnimation),
          { once: true },
        );
      };

      scheduleAfterLoad();
    </script>
  </body>
</html>
