---
const { class: className, ...rest } = Astro.props;
---

<button
  {...rest}
  type="button"
  class:list={[
    "w-full flex items-center text-center bg-accent-dark/80 p-2 rounded-md font-bold cursor-pointer  hover:bg-accent transition-all duration-300 active:bg-accent-active active:translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent",
    className,
  ]}
>
  <slot />
</button>
