---
import { PROJECTS_LIST } from "./data";
import ProjectCard from "./components/project-card.astro";
import { FEATURE_GRID_POSITIONS } from "@/layouts/grid-config";
import { BREAKPOINT_3XL } from "@/shared/constants/breakpoints";

const carouselSlideStyles = PROJECTS_LIST.map(
  (_, index) =>
    `[data-slider]:has(#proj-slide-${index}:checked) [data-slider-track]{transform:translateX(-${index * 100}cqw)}`,
).join("");

// Solo aplicar el desplazamiento del carrusel por debajo de 3xl; en desktop se muestran los 3 a la vez.
const carouselStyles = `@media (max-width: calc(${BREAKPOINT_3XL} - 0.0625rem)){${carouselSlideStyles}}`;
---

<section
  class={`card w-full flex flex-col ${FEATURE_GRID_POSITIONS.projects}`}
  aria-labelledby="projects-heading"
>
  <header class="flex items-center text-start justify-between gap-2 mb-3">
    <h2 id="projects-heading" class="flex gap-3">
      <span class="text-accent font-heading hidden 3xl:block">Featured</span>
      Projects
    </h2>
  </header>

  <div
    data-slider
    role="region"
    aria-roledescription="carousel"
    aria-label="Projects"
    class="overflow-x-clip w-full relative flex-1 flex flex-col min-h-0 @container"
  >
    <ul
      data-slider-track
      class="flex flex-1 min-h-0 shrink-0 self-start transition-transform duration-300 ease-in-out
        3xl:w-full 3xl:gap-6"
    >
      {
        PROJECTS_LIST.map((project, index) => (
          <ProjectCard
            {...project}
            baseIndex={index}
            totalSlides={PROJECTS_LIST.length}
          />
        ))
      }
    </ul>

    <nav
      aria-label="Project slides"
      class="absolute left-1/2 -translate-x-1/2 top-48 md:top-49 flex items-center gap-2 3xl:hidden"
    >
      {
        PROJECTS_LIST.map((_, i) => (
          <label class="relative size-3 cursor-pointer">
            <input
              type="radio"
              name="projects-carousel"
              id={`proj-slide-${i}`}
              class="peer absolute inset-0 size-full opacity-0 cursor-pointer"
              checked={i === 0}
              data-slider-radio
              aria-label={`Go to project ${i + 1}`}
            />
            <span
              class="block size-3 rounded-full ring-1 ring-white bg-surface transition-colors peer-checked:bg-accent peer-focus-visible:outline peer-focus-visible:outline-accent"
              aria-hidden="true"
            />
          </label>
        ))
      }
    </nav>
  </div>
</section>

<style is:global set:html={carouselStyles}></style>
