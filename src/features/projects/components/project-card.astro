---
import { Image } from "astro:assets";
import type { Project } from "./../types";
import GithubIco from "@/shared/components/icons/social/github-ico.astro";
import { ExternalLinkIco } from "@/shared/components/icons/ui";
import { TECH_STACK } from "../../tech-stack/data";

interface Props {
  project: Project;
  index: number;
}

const {
  project: {
    title,
    description,
    image,
    imageAlt,
    projectURL,
    githubURL,
    techs,
  },
  index,
} = Astro.props as Props;

const isLcpCandidate = index === 0;

const techIcons = techs
  .map((tech) => TECH_STACK.find((item) => item.label === tech))
  .filter((item): item is NonNullable<typeof item> => Boolean(item));
---

<li class=" relative w-1/3 h-full shrink-0 3xl:shrink 3xl:border 3xl:border-border 3xl:rounded-md " aria-label={`${title} project`}>
  <article class="flex flex-col gap-3">
    <figure class="h-40 w-full 3xl:h-50 overflow-hidden rounded-md xl:h-35 ">
      <Image
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover select-none"
        sizes="(max-width: 768px) 100vw, 33vw"
        loading={isLcpCandidate ? "eager" : "lazy"}
        fetchpriority={isLcpCandidate ? "high" : undefined}
        decoding={isLcpCandidate ? "sync" : "async"}
      />
    </figure>

    <header class="mt-4 flex items-center justify-between gap-2  px-2 3xl:mt-0">
      <h3 class="text-2xl font-medium">{title}</h3>

      <nav
        class="flex items-center gap-2 text-muted  px-2"
        aria-label={`Links for ${title}`}
      >
        <a
          href={githubURL}
          target="_blank"
          rel="noopener noreferrer"
          title={`${title} GitHub repository`}
          class="transition-colors hover:text-accent"
        >
          <GithubIco class="size-5 md:size-6" aria-hidden="true" />
        </a>

        <a
          href={projectURL}
          target="_blank"
          rel="noopener noreferrer"
          title={`${title} live site`}
          class="transition-colors hover:text-accent"
        >
          <ExternalLinkIco class="size-5 md:size-6" aria-hidden="true" />
        </a>
      </nav>
    </header>

    <p class="text-[0.95rem]  px-2 leading-relaxed md:text-base ">{description}</p>

    <ul
      class="flex items-center justify-end gap-2 text-white 3xl:absolute 3xl:right-4 3xl:bottom-4"
      aria-label={`Technologies used in ${title}`}
    >
      {
        techIcons.map(({ Icon, label }) => (
          <li aria-label={label}>
            <Icon
              class="size-6 transition-colors hover:text-accent"
              aria-hidden="true"
            />
          </li>
        ))
      }
    </ul>
  </article>
</li>
