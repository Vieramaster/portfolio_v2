---
import { Image } from "astro:assets";
import { ExternalLinkIco } from "@/shared/components/icons/ui";
import { GitHubIco } from "@/shared/components/icons/social";
import { TECH_STACK } from "@/features/tech-stack/data";
import type { Project } from "../types";

interface Props extends Project {
  baseIndex: number;
  totalSlides: number;
}

const {
  title,
  description,
  image,
  imageAlt,
  projectURL,
  githubURL,
  techs,
  baseIndex,
  totalSlides,
} = Astro.props;

const linkIconClass =
  "size-5 md:size-6 hover:text-accent ease-in-out duration-200";

const altText = imageAlt ?? `Screenshot of ${title} — ${description}`;

const links = [
  { Icon: GitHubIco, href: githubURL, label: "GitHub" },
  { Icon: ExternalLinkIco, href: projectURL, label: "Live" },
];
---

<li class="min-w-full h-full 3xl:w-1/3 3xl:min-w-auto">
  <article
    data-slider-slide
    role="group"
    aria-roledescription="slide"
    aria-label={`${title}, slide ${baseIndex + 1} of ${totalSlides}`}
    class="overflow-x-hidden flex flex-col gap-3 h-full relative 3xl:border 3xl:rounded-md 3xl:border-border"
    hidden={baseIndex > 0}
    inert={baseIndex > 0}
    aria-hidden={baseIndex > 0}
    aria-current={baseIndex === 0}
  >
    <figure class="group block h-48 overflow-hidden rounded-md 3xl:h-50 m-0">
      <Image
        src={image}
        alt={altText}
        sizes="(max-width: 768px) 100vw, 33vw"
        class="block h-full w-full object-cover transition-transform duration-300 ease-in-out will-change-transform group-hover:scale-105"
      />
    </figure>

    <header class="flex items-center justify-between gap-2 3xl:px-4">
      <h3 class="text-xl md:text-2xl text-accent m-0">
        {title}
      </h3>

      <div class="flex items-center gap-2 text-sm text-muted">
        {
          links.map(({ Icon, href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${title} ${label} (opens in new tab)`}
              class="rounded-sm transition-colors hover:text-accent"
            >
              <Icon class={linkIconClass} aria-hidden="true" />
            </a>
          ))
        }
      </div>
    </header>

    <p
      class="text-sm text-[0.95rem] xl:text-[0.92rem] 3xl:text-[0.95rem] 3xl:px-4"
    >
      {description}
    </p>

    <ul
      class="flex items-center gap-2 justify-end text-white 3xl:absolute 3xl:right-4 3xl:bottom-4"
      aria-label={`Technologies used in ${title}`}
    >
      {
        techs.map((tech) => {
          const item = TECH_STACK.find(({ label }) => label === tech);
          if (!item) return null;

          const Icon = item.Icon;

          return (
            <li aria-label={item.label}>
              <Icon class={linkIconClass} aria-hidden="true" />
            </li>
          );
        })
      }
    </ul>
  </article>
</li>
