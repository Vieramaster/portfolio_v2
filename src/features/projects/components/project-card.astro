---
import { Image } from "astro:assets";

import { ExternalLinkIco } from "@/shared/components/icons/ui";
import { GitHubIco } from "@/shared/components/icons/social";

import { TECH_STACK } from "@/features/tech-stack/data";

import type { Project } from "../types";

interface Props extends Project {
  baseIndex: number;
  totalSlides: number;
}

const {
  title,
  description,
  image,
  imageAlt,
  projectURL,
  githubURL,
  techs,
  baseIndex,
  totalSlides,
} = Astro.props;

const isActive = baseIndex === 0;
const isLcpCandidate = isActive;

const iconClass = "size-5 md:size-6 hover:text-accent ease-in-out duration-200";

const altText = imageAlt ?? `Screenshot of ${title} — ${description}`;

const links = [
  {
    href: githubURL,
    label: "GitHub",
    Icon: GitHubIco,
  },
  {
    href: projectURL,
    label: "Live",
    Icon: ExternalLinkIco,
  },
];

const techIcons = techs
  .map((tech) => TECH_STACK.find((item) => item.label === tech))
  .filter(Boolean);
---

<li
  class="w-[100cqw] h-full shrink-0 grow-0 basis-[100cqw] overflow-hidden 3xl:w-1/3 3xl:basis-auto 3xl:shrink"
>
  <article
    data-slider-slide
    role="group"
    aria-roledescription="slide"
    aria-label={`${title}, slide ${baseIndex + 1} of ${totalSlides}`}
    inert={!isActive}
    aria-hidden={!isActive}
    aria-current={isActive}
    class="relative flex h-full flex-col gap-4 overflow-x-hidden 3xl:rounded-md 3xl:border 3xl:border-border"
  >
    <figure class="group m-0 block h-46 overflow-hidden rounded-md 3xl:h-50">
      <Image
        src={image}
        alt={altText}
        sizes="(max-width: 768px) 100vw, 33vw"
        class="block h-full w-full object-cover transition-transform duration-300 ease-in-out will-change-transform group-hover:scale-105"
        loading={isLcpCandidate ? "eager" : "lazy"}
        fetchpriority={isLcpCandidate ? "high" : undefined}
        decoding={isLcpCandidate ? "sync" : "async"}
      />
    </figure>

    <div class="3xl:px-4 flex flex-col gap-3">
      <header class="mt-3 flex items-center justify-between gap-2">
        <h3>{title}</h3>

        <div class="flex items-center gap-2 text-muted">
          {
            links.map(({ href, label, Icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${title} ${label} (opens in new tab)`}
                class="rounded-sm transition-colors hover:text-accent"
              >
                <Icon class={iconClass} aria-hidden="true" />
              </a>
            ))
          }
        </div>
      </header>

      <p class="text-[0.95rem]">{description}</p>
    </div>
    <ul
      aria-label={`Technologies used in ${title}`}
      class="flex items-center justify-end gap-2 text-white 3xl:absolute 3xl:right-4 3xl:bottom-4"
    >
      {
        techIcons.map((item) => {
          if (!item) return null;
          const Icon = item.Icon;

          return (
            <li aria-label={item.label}>
              <Icon class={iconClass} aria-hidden="true" />
            </li>
          );
        })
      }
    </ul>
  </article>
</li>
