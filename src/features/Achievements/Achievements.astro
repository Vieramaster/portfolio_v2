---
import { ACHIEVEMENTS_LIST } from "./data";
---

<section
  class="w-full
 max-md:col-auto max-md:row-auto
 md:size-full md:col-start-1 col-end-3 md:row-start-22 md:row-span-2
 xl:row-start-14 xl:row-span-2 xl:h-full"
  aria-labelledby="achievements-heading"
>
  <h2 id="achievements-heading" class="sr-only">Achievements</h2>

  <ul
    class="flex flex-col gap-4 md:flex-row xl:h-full xl:items-stretch xl:gap-6"
  >
    {
      ACHIEVEMENTS_LIST.map(({ title, description, Icon }, index) => (
        <li class="xl:flex-1 xl:h-full">
          <article
            class="flex items-center gap-7 card text-sm md:text-base xl:h-full"
            aria-labelledby={`achievement-title-${index} achievement-description-${index}`}
          >
            <header class="w-1/4 flex items-center gap-3 md:w-1/3">
              <Icon
                aria-hidden="true"
                title={`${title} — ${description}`}
                class={`size-10 shrink-0 ${index !== 2 ? "stroke-accent" : "fill-accent"}`}
              />
              <h3 id={`achievement-title-${index}`} class="m-0">{title}</h3>
            </header>
            <p id={`achievement-description-${index}`} class="m-0">{description}</p>
          </article>
        </li>
      ))
    }
  </ul>
</section>
