---
import { ACHIEVEMENTS_LIST } from "./data";
---

<ul
  class="w-full flex flex-col gap-4
    max-md:col-auto max-md:row-auto
   md:flex-row md:size-full md:col-start-1 md:col-end-3 md:row-start-22 md:row-span-2
    xl:row-start-14 xl:row-span-2 xl:h-full  xl:gap-6"
  aria-label="Achievements"
>
  {
    ACHIEVEMENTS_LIST.map(({ title, description, Icon }, index) => (
      <li class="xl:flex-1 xl:h-full w-1/3">
        <article
          class="card flex items-center gap-6 text-sm md:text-base xl:h-full"
          aria-labelledby={`achievement-title-${index} achievement-description-${index}`}
        >
          <header class="flex w-1/4 items-center gap-2 md:w-1/3">
            <Icon
              aria-hidden="true"
              title={`${title} — ${description}`}
              class={`size-10 shrink-0 ${
                index !== 2 ? "stroke-accent" : "fill-accent"
              }`}
            />
            <h2 id={`achievement-title-${index}`} class="m-0">
              {title}
            </h2>
          </header>

          <p id={`achievement-description-${index}`} class="m-0">
            {description}
          </p>
        </article>
      </li>
    ))
  }
</ul>
