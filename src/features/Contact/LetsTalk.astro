---
import { ArrowRightIco } from "@/shared/components/icons/ui";
import { LETS_TALK_ITEMS } from "./data";
import Button from "@/shared/components/ui/Button.astro";
import DialogForm from "./dialog/DialogForm.astro";

const contactRowClass = "flex items-center gap-2 text-sm m-0";
const contactLinkTextClass =
  "leading-none xl:text-base text-muted! transition-colors group-hover:text-accent!";
---

<section
  class="card w-full flex flex-col gap-4 justify-center
  max-md:col-auto
  col-start-1 md:row-start-8 md:row-span-4 md:size-full
  xl:row-start-8 xl:row-span-4 3xl:row-span-4
  3xl:gap-5"
  aria-labelledby="lets-talk-heading"
>
  <h2 id="lets-talk-heading" class="sr-only">Contact</h2>

  {
    LETS_TALK_ITEMS.map(
      ({ Icon, iconClass, type, href, download, content, textClass }) =>
        href ? (
          <p class={contactRowClass}>
            <Icon aria-hidden="true" class={iconClass} title={content} />
            <a
              href={href}
              download={download}
              aria-label={content}
              title={content}
              class="group flex items-center gap-2 transition-colors rounded-sm"
            >
              <span class={contactLinkTextClass}>
                {content}
              </span>
            </a>
          </p>
        ) : (
          <p
            class={contactRowClass}
            role={type === "status" ? "status" : undefined}
          >
            <Icon aria-hidden="true" class={iconClass} title={content} />
            <span class={textClass ?? "leading-none xl:text-base"}>
              {content}
            </span>
          </p>
        ),
    )
  }

  <Button
    aria-haspopup="dialog"
    aria-controls="contact-modal"
    aria-expanded="false"
    aria-label="Open contact form"
    title="Let's Talk"
  >
    <span class="flex-1 text-surface! xl:text-xl">Let's Talk!</span>

    <ArrowRightIco
      class="shrink-0 stroke-surface xl:size-7"
      aria-hidden="true"
    />
  </Button>
</section>
<DialogForm />

<script>
  import { dialogHandler } from "./dialog/logic";

  dialogHandler();
</script>
