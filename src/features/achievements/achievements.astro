---
import { ACHIEVEMENTS_LIST } from "./data";
---

<ul
  class="w-full flex flex-col gap-4
    max-md:col-auto max-md:row-auto
    md:flex-row md:size-full md:col-start-1 md:col-end-3 md:row-start-22 md:row-span-2
    xl:row-start-14 xl:row-span-2 xl:h-full xl:gap-6"
  aria-label="Achievements"
>
  {
    ACHIEVEMENTS_LIST.map(({ title, description, Icon }, index) => (
      <li class="xl:flex-1 xl:h-full card flex  gap-4 text-sm md:text-base justify-between items-center">
        <div class="flex items-center gap-2 w-1/3">
          <Icon
            aria-hidden="true"
            class={`size-10 shrink-0 ${
              index !== 2 ? "stroke-accent" : "fill-accent"
            }`}
          />
          <span>{title}</span>
        </div>

        <p class="w-2/3 md:text-center">{description}</p>
      </li>
    ))
  }
</ul>
