---
import { FEATURE_GRID_POSITIONS } from "@/layouts/data/grid-config";
import { TECH_STACK, TECH_TOOLS } from "./data";
---

<section
  class={`card w-full flex flex-col gap-3 justify-between ${FEATURE_GRID_POSITIONS.techStack}`}
  aria-labelledby="tech-stack-heading"
>
  <h2 id="tech-stack-heading">Tech Stack</h2>

  <h3 class="text-center">Core</h3>

  <ul class="flex flex-wrap gap-4 justify-center items-center">
    {
      TECH_STACK.map(({ Icon, label }) => {
        return (
          <li
            class="shrink-0 size-8 md:size-11 xl:size-9 3xl:size-11 "
            title={label}
          >
            <Icon aria-hidden="true" />
            <span class="sr-only">{label}</span>
          </li>
        );
      })
    }
  </ul>

  <h3 class="text-center">Tools</h3>

  <ul class="flex flex-wrap justify-center gap-2 list-none 3xl:gap-3">
    {
      TECH_TOOLS.map((toolName) => (
        <li class="px-2 py-1 rounded-md bg-background/50">{toolName}</li>
      ))
    }
  </ul>
</section>
