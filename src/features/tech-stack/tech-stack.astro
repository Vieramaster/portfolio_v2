---
import { TECH_STACK, TECH_TOOLS } from "./data";

const subsectionTitleClass = "text-center text-2xl subTitle";
---

<section
  class="card w-full flex flex-col gap-2 justify-center
  md:col-start-1 md:row-start-12 md:row-span-8 md:size-full
  xl:col-start-2 xl:row-start-7 xl:row-span-7
  3xl:row-start-6 3xl:row-span-8"
  aria-labelledby="tech-stack-heading"
>
  <h2 id="tech-stack-heading" class="subTitle text-2xl md:text-3xl">Tech Stack</h2>

  <h3 class={subsectionTitleClass}>Core</h3>

  <ul class="flex flex-wrap gap-5 justify-center items-center">
    {
      TECH_STACK.map(({ Icon, label }) => {
        return (
          <li class="shrink-0 size-8" title={label}>
            <Icon aria-hidden="true" />
            <span class="sr-only">{label}</span>
          </li>
        );
      })
    }
  </ul>

  <h3 class={subsectionTitleClass}>Tools</h3>

  <ul class="flex flex-wrap justify-center gap-3 list-none">
    {
      TECH_TOOLS.map((toolName) => (
        <li class="px-2 py-1 rounded-md bg-background/50">{toolName}</li>
      ))
    }
  </ul>
</section>
