---
import { ExternalLinkIco } from "@/shared/components/icons/ui";
import { GitHubIco } from "@/shared/components/icons/social";
import { TECH_STACK } from "@/features/TechStack/data";
import type { Project } from "./types";

interface Props extends Project {
  baseIndex: number;
  totalSlides: number;
}

const {
  title,
  description,
  images,
  imageAlt,
  url,
  github,
  techs,
  baseIndex,
  totalSlides,
} = Astro.props;

const linkIconClass =
  "size-5 md:size-6 hover:text-accent ease-in-out duration-200";
const projectImageClass =
  "block h-full w-full object-cover transition-transform duration-300 ease-in-out will-change-transform group-hover:scale-105";
const altText = imageAlt ?? `Screenshot of ${title} — ${description}`;
---

<li class="min-w-full h-full 3xl:w-1/3 3xl:min-w-auto">
  <div
    data-slider-slide
    role="group"
    aria-roledescription="slide"
    aria-label={`${title}, slide ${baseIndex + 1} of ${totalSlides}`}
    class="overflow-x-hidden flex flex-col gap-3 h-full relative 3xl:border 3xl:rounded-md 3xl:border-border"
    hidden={baseIndex > 0}
    inert={baseIndex > 0 ? true : undefined}
    aria-hidden={baseIndex > 0 ? "true" : undefined}
    aria-current={baseIndex === 0 ? "true" : undefined}
  >
    <figure class="group block h-48 overflow-hidden rounded-md 3xl:h-50 m-0">
      <img src={images} alt={altText} class={projectImageClass} />
    </figure>

    <header class="flex items-center justify-between gap-2 3xl:px-4">
      <h3 class="text-xl md:text-2xl text-accent m-0">
        {title}
      </h3>

      <nav
        aria-label={`${title} links`}
        class="flex items-center gap-2 text-sm text-muted"
      >
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} live website (opens in new tab)`}
          title={`${title} live website (opens in new tab)`}
          class="rounded-sm transition-colors hover:text-accent"
        >
          <ExternalLinkIco class={`${linkIconClass} mt-1`} aria-hidden="true" />
        </a>

        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} source code on GitHub (opens in new tab)`}
          title={`${title} source code on GitHub (opens in new tab)`}
          class="rounded-sm transition-colors hover:text-accent"
        >
          <GitHubIco class={`${linkIconClass} mt-1`} aria-hidden="true" />
        </a>
      </nav>
    </header>

    <p
      class="text-sm text-[0.95rem] xl:text-[0.92rem] 3xl:text-[0.95rem] 3xl:px-4"
    >
      {description}
    </p>
    <ul
      class="flex items-center gap-2 justify-end text-white 3xl:absolute 3xl:right-4 3xl:bottom-4"
      aria-label={`Technologies used in ${title}`}
    >
      {
        techs.map((tech) => {
          const item = TECH_STACK.find(({ label }) => label === tech);
          if (!item) return null;
          const Icon = item.Icon;
          return (
            <li title={item.label}>
              <Icon class={linkIconClass} aria-hidden="true" />
              <span class="sr-only">{item.label}</span>
            </li>
          );
        })
      }
    </ul>
  </div>
</li>
