---
import { CloseIco } from "@/shared/components/icons/ui";
import { FORM_FIELDS, FORM_CONFIG } from "./data";
import { PROFILE } from "@/shared/constants/profile";

const fieldClass =
  "rounded bg-dialog-input p-3 font-mono text-dialog-text focus:outline-none";
---

<dialog
  id="contact-modal"
  aria-labelledby="contact-modal-title"
  class="m-auto w-full max-w-md rounded-md border-0 bg-dialog-surface p-4"
>
  <button
    type="button"
    commandfor="contact-modal"
    command="close"
    aria-label="Close dialog"
    class="absolute top-4 right-4 cursor-pointer"
  >
    <CloseIco class="size-6 stroke-dialog-label" aria-hidden="true" />
  </button>

  <form
    action={`https://formsubmit.co/${PROFILE.social.email}`}
    method="POST"
    class="flex flex-col gap-4"
  >
    <h2 id="contact-modal-title" class="m-0 text-3xl text-dialog-title">
      Send me a message!
    </h2>

    {
      FORM_FIELDS.map(
        ({ type, name, placeholder, rows, autocomplete, label }) => (
          <label for={name} class="flex flex-col gap-1 text-dialog-label">
            <span class="font-semibold">{label}</span>

            {type === "textarea" ? (
              <textarea
                id={name}
                class={fieldClass}
                name={name}
                placeholder={placeholder}
                rows={rows ?? 5}
                required
              />
            ) : (
              <input
                id={name}
                class={fieldClass}
                type={type}
                name={name}
                placeholder={placeholder}
                autocomplete={autocomplete}
                required
              />
            )}
          </label>
        ),
      )
    }

    {
      FORM_CONFIG.map(({ name, value }) => (
        <input type="hidden" name={name} value={value} />
      ))
    }

    <input
      type="text"
      name="_honey"
      class="hidden"
      tabindex="-1"
      autocomplete="off"
    />

    <button
      type="submit"
      class="self-end w-1/2 cursor-pointer rounded-md border-2 border-accent px-4 py-2 font-semibold text-white duration-300 hover:bg-accent hover:text-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-dialog-ring"
    >
      Send
    </button>
  </form>
</dialog>
