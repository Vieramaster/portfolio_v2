---
import { ArrowRightIco } from "@/shared/components/icons/ui";

import {
  CurriculumIco,
  CircleIco,
  MapPinIco,
} from "@/shared/components/icons/ui/";

const BASE_ICON_CLASS = "size-5 shrink-0 text-accent";
const BASE_LI_CLASS = "flex items-center gap-4 ";
---

<section
  class="card w-full flex flex-col gap-4 justify-center
  max-md:col-auto
  col-start-1 md:row-start-8 md:row-span-4 md:size-full
  xl:row-start-8 xl:row-span-4 3xl:row-span-4
  3xl:gap-6"
  aria-labelledby="lets-talk-heading"
>
  <h2 id="lets-talk-heading" class="sr-only">Contact</h2>

  <ul class="flex flex-col gap-3">
    <li class={BASE_LI_CLASS}>
      <CircleIco class={BASE_ICON_CLASS} />
      <p
        class="animate-pulse [animation-duration:3s] leading-none text-accent!"
      >
        AVAILABLE FOR WORK
      </p>
    </li>

    <li class={BASE_LI_CLASS}>
      <MapPinIco class={`${BASE_ICON_CLASS} stroke-accent fill-accent`} />
      <p>Mar del Plata, Argentina</p>
    </li>

    <li class={BASE_LI_CLASS}>
      <CurriculumIco class={BASE_ICON_CLASS} />
      <a
        href="/public/cv/martin-viera-cv.pdf"
        download="martin-viera-CV.pdf"
        aria-label="Download curriculum vitae PDF"
        class="text-secondary"
      >
        Download Curriculum
      </a>
    </li>
  </ul>

  <button
    aria-haspopup="dialog"
    aria-controls="contact-modal"
    commandfor="contact-modal"
    command="show-modal"
    type="button"
    class="w-full flex items-center text-center bg-accent-dark/80 p-2 rounded-md font-bold cursor-pointer hover:bg-accent transition-all duration-300 active:bg-accent-active active:translate-y-1 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
  >
    <span class="flex-1 text-surface! xl:text-xl font-black">Let's Talk!</span>

    <ArrowRightIco
      class="shrink-0 stroke-surface xl:size-7"
      aria-hidden="true"
    />
  </button>
</section>
