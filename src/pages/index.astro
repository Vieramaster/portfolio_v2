    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>Astro</title>
  </head>
  <body class="bg-background">
    <main class="w-85 mx-auto py-5 grid grid-cols-1 gap-5 place-items-center">
      <PhotoCard />
      <LetsTalkCard />
      <SocialCard />
      <AboutMe />
      <TechCard />
    </main> 
