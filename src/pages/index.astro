---
import { getImage } from "astro:assets";
import BaseLayout from "@/layouts/base-layout.astro";
import { MAIN_GRID_CLASS } from "@/layouts/grid-config";
import { PROFILE } from "@/shared/constants/profile";
import { PROJECTS_LIST } from "@/features/projects/data";

import {
  Hero,
  LetsTalk,
  Projects,
  AboutMe,
  TechStack,
  Socials,
  Achievements,
  DialogForm,
} from "@/features";

const projectLcp = await getImage({
  src: PROJECTS_LIST[0].image,
  width: 600,
  height: 289,
  format: "webp",
});
---

<BaseLayout>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={projectLcp.src}
    fetchpriority="high"
  />
  <main id="main-content" class={MAIN_GRID_CLASS}>
    <Hero />
    <LetsTalk />
    <AboutMe />
    <Projects />
    <TechStack />
    <Achievements />
    <Socials />
    <DialogForm />
    <footer class="sr-only">{PROFILE.name} portfolio</footer>
  </main>
</BaseLayout>

<script>
  import { initClient } from "@/layouts/logic/init";

  initClient();
</script>
