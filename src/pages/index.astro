---
import BaseLayout from "@/layouts/BaseLayout.astro";

import {
  Hero,
  LetsTalk,
  Projects,
  AboutMe,
  TechStack,
  Socials,
  Achievements,
} from "@/features";

const mainGridClass = [
  "w-80 mx-auto py-6 min-h-dvh grid grid-cols-1 gap-4 place-items-center place-content-center",
  "max-md:w-full max-md:max-w-80 max-md:px-4 max-md:min-h-0 max-md:place-items-stretch max-md:place-content-start max-md:gap-5",
  "md:w-180 md:grid-cols-2 md:grid-rows-[repeat(23,2rem)]",
  "xl:w-6xl xl:grid-cols-3 xl:grid-rows-[repeat(15,2rem)] xl:gap-6",
  "3xl:w-450 3xl:grid-cols-5",
].join(" ");
---

<BaseLayout>
  <main id="main-content" class={mainGridClass}>
    <Hero />
    <LetsTalk />
    <AboutMe />
    <Projects />
    <TechStack />
    <Achievements />
    <Socials />
    <footer class="sr-only">Martin Viera portfolio</footer>
  </main>
</BaseLayout>

<script>
  import { initClient } from "@/layouts/logic/init";

  initClient();
</script>
