---
import BaseLayout from "@/layouts/base-layout.astro";
import { MAIN_GRID_CLASS } from "@/layouts/grid-config";
import { PROFILE } from "@/shared/constants/profile";

import {
  Hero,
  LetsTalk,
  Projects,
  AboutMe,
  TechStack,
  Socials,
  Achievements,
  DialogForm,
} from "@/features";
---

<BaseLayout>
  <main id="main-content" class={MAIN_GRID_CLASS}>
    <Hero />
    <LetsTalk />
    <AboutMe />
    <Projects />
    <TechStack />
    <Achievements />
    <Socials />
    <DialogForm />
    <footer class="sr-only">{PROFILE.name} portfolio</footer>
  </main>
</BaseLayout>

<script>
  import { initClient } from "@/layouts/logic/init";

  initClient();
</script>
