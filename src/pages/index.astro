---
import { getImage } from "astro:assets";
import BaseLayout from "@/layouts/base-layout.astro";
import { FEATURE_GRID_POSITIONS } from "@/shared/constants/feature-grid-positions";
import { PROFILE } from "@/shared/constants/profile";
import { PROJECTS_LIST } from "@/features/projects/data";

import {
  Hero,
  LetsTalk,
  Projects,
  AboutMe,
  TechStack,
  Socials,
  Achievements,
  DialogForm,
} from "@/features";

const projectLcp = await getImage({
  src: PROJECTS_LIST[0].image,
});
---

<BaseLayout>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={projectLcp.src}
    fetchpriority="high"
  />
  <main id="main-content" class={FEATURE_GRID_POSITIONS.main}>
    <Hero />
    <LetsTalk />
    <AboutMe />
    <Projects />
    <TechStack />
    <Achievements />
    <Socials />
    <DialogForm />
    <footer class="sr-only">{PROFILE.name} portfolio</footer>
  </main>
</BaseLayout>
