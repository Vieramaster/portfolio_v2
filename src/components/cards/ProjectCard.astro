---
import { ExternalLinkIco } from "../icons/ui";
import { GitHubIco } from "../icons/social";
import { TECH_STACK } from "@/data/techList";
import type { Project } from "@/types";

interface Props extends Project {
  baseIndex: number;
}

const { title, description, images, imageAlt, url, github, techs, baseIndex } =
  Astro.props;

const iconClass = "size-5 md:size-6 hover:text-accent ease-in-out duration-200";
const altText = imageAlt ?? `Screenshot of ${title} — ${description}`;
---

<article
  data-slider-slide
  class="flex flex-col gap-3 min-w-full h-full relative 3xl:w-1/3 3xl:min-w-auto 3xl:border 3xl:rounded-md 3xl:border-border  3xl:px-4 "
  hidden={baseIndex > 0}
  inert={baseIndex > 0 ? true : undefined}
  aria-hidden={baseIndex > 0 ? "true" : undefined}
>
  <picture>
    <source
      media="(max-width: 767px)"
      srcset={images.mobile}
      type="image/webp"
    />
    <img
      src={images.desktop}
      alt={altText}
      class="h-36 w-full rounded-md object-cover"
    />
  </picture>

  <header class="flex items-center justify-between gap-2">
    <h3 class="text-xl md:text-2xl text-accent">
      {title}
    </h3>

    <div class="flex items-center gap-2 text-sm text-muted">
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${title} live website (opens in new tab)`}
      >
        <ExternalLinkIco class={`${iconClass} mt-1`} aria-hidden="true" />
      </a>

      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${title} source code on GitHub (opens in new tab)`}
      >
        <GitHubIco class={`${iconClass} mt-1`}aria-hidden="true" />
      </a>
    </div>
  </header>

  <p class="text-sm text-[0.95rem] xl:text-[0.92rem] 3xl:text-[0.95rem]">
    {description}
  </p>
  <ul
    class="flex items-center gap-2 justify-end text-white 3xl:absolute 3xl:right-4 3xl:bottom-4"
    aria-label={`Technologies used in ${title}`}
  >
    {
      techs.map((tech) => {
        const item = TECH_STACK.find(({ label }) => label === tech);
        if (!item) return null;
        const Icon = item.Icon;
        return (
          <li>
            <Icon class={iconClass} aria-hidden="true" />
            <span class="sr-only">{item.label}</span>
          </li>
        );
      })
    }
  </ul>
</article>
