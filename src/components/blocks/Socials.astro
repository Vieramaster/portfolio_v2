---
import { SOCIAL_LINKS } from "@/data/socialLinksList";
---

<nav
  aria-labelledby="socials-heading"
  class="card w-full flex flex-col gap-3
max-md:col-auto 
md:size-full md:col-start-1 md:row-start-20 row-span-2 justify-center
xl:col-start-1 xl:row-start-12 xl:row-span-2 
3xl:row-span-2 3xl:row-start-12"
>
  <h2 id="socials-heading" class="sr-only">Let's Connect!</h2>

  <ul class="flex gap-5 justify-center items-center">
    {
      SOCIAL_LINKS.map(({ Icon, link, label }) => {
        return (
          <li class="shrink-0 size-9 hover:-translate-y-1 group transition-all duration-300 md:size-11">
            <a
              href={link}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${label} (opens in new tab)`}
              title={label}
              class="touch-target rounded-sm transition-colors group-hover:text-accent"
            >
              <Icon
                class="group-hover:text-accent transition-all duration-300"
                aria-hidden="true"
              />
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
