---
import { ACHIEVEMENTS_LIST } from "@/data/achievementsList";
---

<section
  class="w-full
 max-md:col-auto max-md:row-auto
 md:size-full md:col-start-1 col-end-3 md:row-start-19 md:row-span-2
 xl:row-start-14 xl:row-span-2 xl:h-full
 "
  aria-labelledby="achievements-heading"
>
  <h2 id="achievements-heading" class="sr-only">Achievements</h2>
  <ul class="flex flex-col gap-4 md:flex-row xl:h-full xl:items-stretch xl:gap-6">
    {
      ACHIEVEMENTS_LIST.map(({ title, description, Icon }, index) => (
        <li class="flex items-center gap-6 card xl:flex-1 xl:h-full">
          <div class="w-1/4  flex items-center gap-3 md:w-1/3">
            <Icon
              aria-hidden="true"
              class={`size-8 shrink-0 ${index !== 2 ? "stroke-accent" : "fill-accent"}`}
            />
            <h3>
              <span class="sr-only">{description}</span>
              {title}
            </h3>
          </div>
          <p>{description}</p>
        </li>
      ))
    }
  </ul>
</section>
