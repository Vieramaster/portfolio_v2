---
import { PROJECTS_LIST } from "@/data/projectsList";

import ProjectCard from "../cards/ProjectCard.astro";

import { ChevronArrowIco } from "../icons/ui";

const controlBtnClass =
  "h-7 text-accent cursor-pointer enabled:hover:[&_svg]:scale-110 disabled:cursor-not-allowed disabled:text-muted disabled:[&_svg]:stroke-muted transition-colors duration-200 ease-in-out";

const titleClass = "text-2xl md:text-3xl font-semibold text-accent!";
---

<section
  class="card w-full flex flex-col
        md:size-full md:col-start-2 md:row-start-10 md:row-span-12
        xl:col-start-3 xl:row-start-6 xl:row-span-10
        3xl:col-end-6 3xl:row-start-6"
  aria-labelledby="projects-heading"
>
  <div class="flex items-center text-start justify-between gap-2 mb-3">
    <h3 id="projects-heading" class={`${titleClass} flex gap-3`}>
      <span class={`${titleClass} hidden 3xl:block`}>Featured</span> Projects
    </h3>

    <p
      data-slider-status
      class="text-md text-muted tabular-nums mt-1 3xl:hidden"
      aria-hidden="true"
    >
      1 / {PROJECTS_LIST.length}
    </p>
  </div>

  <div
    data-slider
    role="region"
    aria-roledescription="carousel"
    aria-label="Projects"
    aria-live="polite"
    tabindex="0"
    class="overflow-hidden w-full relative flex-1 flex flex-col min-h-0"
  >
    <ul
      data-slider-track
      class="flex flex-1 min-h-0 gap-3 transition-transform duration-300 ease-in-out 3xl:gap-6"
    >
      {
        PROJECTS_LIST.map((project, index) => (
          <ProjectCard {...project} baseIndex={index} />
        ))
      }
    </ul>

    <div
      class="absolute top-1/6 w-full flex items-center justify-between gap-2 3xl:hidden"
    >
      <button
        type="button"
        data-slider-prev
        aria-label="Previous project"
        class={controlBtnClass}
        disabled
      >
        <ChevronArrowIco class="rotate-180" aria-hidden="true" />
      </button>

      <button
        type="button"
        data-slider-next
        aria-label="Next project"
        class={controlBtnClass}
      >
        <ChevronArrowIco aria-hidden="true" />
      </button>
    </div>
  </div>
</section>
