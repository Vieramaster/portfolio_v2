---
import { PROJECTS_LIST } from "@/data/projectsList";
import ProjectCard from "../cards/ProjectCard.astro";
import { ChevronArrowIco } from "../icons/ui";

const controlBtnClass =
  "h-7 text-accent cursor-pointer enabled:hover:[&_svg]:scale-110 disabled:cursor-not-allowed disabled:text-muted disabled:[&_svg]:stroke-muted transition-colors duration-200 ease-in-out";
---

<section class="card h-120 w-full" aria-labelledby="projects-heading">
  <div class="flex items-center justify-between gap-2 mb-3">
    <h2 id="projects-heading" class="text-lg">Projects</h2>
    <p
      data-slider-status
      class="text-sm text-muted tabular-nums"
      aria-hidden="true"
    >
      1 / {PROJECTS_LIST.length}
    </p>
  </div>
  <div
    data-slider
    role="region"
    aria-roledescription="carousel"
    aria-label="Projects"
    aria-live="polite"
    tabindex="0"
    class="overflow-hidden w-full relative"
  >
    <div
      data-slider-track
      class="flex transition-transform duration-300 ease-in-out"
    >
      {
        PROJECTS_LIST.map((project, index) => (
          <ProjectCard
            {...project}
            hidden={index > 0}
            aria-hidden={index > 0 ? "true" : undefined}
            inert={index > 0 ? true : undefined}
          />
        ))
      }
    </div>

    <div
      class="absolute top-1/6 w-full flex items-center justify-between gap-2"
    >
      <button
        type="button"
        data-slider-prev
        aria-label="Previous project"
        class={controlBtnClass}
        disabled
      >
        <ChevronArrowIco class="rotate-180" aria-hidden="true" />
      </button>

      <button
        type="button"
        data-slider-next
        aria-label="Next project"
        class={controlBtnClass}
      >
        <ChevronArrowIco aria-hidden="true" />
      </button>
    </div>
  </div>
</section>
