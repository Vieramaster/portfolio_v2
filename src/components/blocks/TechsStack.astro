---
import { TECH_STACK, TECH_TOOLS } from "@/data/techList";
import Title from "../ui/Title.astro";
---

<section
  class="card w-full flex flex-col gap-4 justify-center
  md:col-start-1 md:row-start-10 md:row-span-7 md:size-full
  xl:col-start-2 xl:row-start-6 xl:row-span-8
  "
  aria-labelledby="techs-heading"
>
  <Title title="Tech stack" id="techs-heading" />

  <h3 class="text-accent! text-center">Core Stack</h3>
  <ul class="flex gap-5 justify-center items-center">
    {
      TECH_STACK.map(({ Icon, label }) => {
        return (
          <li class="shrink-0 size-8 xl:size-10">
            <Icon aria-hidden="true" />
            <span class="sr-only">{label}</span>
          </li>
        );
      })
    }
  </ul>

  <h3 class="text-accent! text-center">Tools</h3>
  <ul class="flex flex-wrap justify-center gap-2 list-none">
    {
      TECH_TOOLS.map((item) => (
        <li class="tech-tool-item hover:text-accent! ease-in-out transition-all duration-300 xl:text-lg">
          {item}
        </li>
      ))
    }
  </ul>
</section>
