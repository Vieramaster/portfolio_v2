---
interface Props {
  className?: string;
}

const { className }: Props = Astro.props;
---

<svg
  width="12"
  height="12"
  viewBox="0 0 24 24"
  fill="currentColor"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}><circle cx="12" cy="12" r="10"></circle></svg
>
